---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Base from "../../../layouts/Base.astro";
import VimRunner from "../../../components/VimRunner.astro";
import { lessonTitle, lessonNumber } from "../../../lib/titles";

type LessonLink = { href: string; number: number | null; title: string };

const demos = import.meta.glob<string>("/lessons/**/*.demo", {
  query: "?raw",
  import: "default",
  eager: true,
});
const goals = import.meta.glob<string>("/lessons/**/*.goal", {
  query: "?raw",
  import: "default",
  eager: true,
});

export async function getStaticPaths() {
  const stepNum = (entry: CollectionEntry<"lessons">): number => {
    const m = entry.id.split("/")[1]?.match(/^(\d+)/);
    return m ? parseInt(m[1], 10) : 0;
  };

  const all = await getCollection("lessons");

  const grouped = new Map<string, CollectionEntry<"lessons">[]>();
  for (const entry of all) {
    const [lesson] = entry.id.split("/");
    if (!grouped.has(lesson)) grouped.set(lesson, []);
    grouped.get(lesson)!.push(entry);
  }
  for (const list of grouped.values()) {
    list.sort((a, b) => stepNum(a) - stepNum(b));
  }

  const orderedLessons = [...grouped.keys()].sort((a, b) => {
    const an = lessonNumber(a) ?? 0;
    const bn = lessonNumber(b) ?? 0;
    return an - bn;
  });

  const paths: Array<{
    params: { lesson: string; step: string };
    props: {
      entry: CollectionEntry<"lessons">;
      step: number;
      totalSteps: number;
      prevLesson: LessonLink | null;
      nextLesson: LessonLink | null;
    };
  }> = [];

  orderedLessons.forEach((lesson, lessonIdx) => {
    const list = grouped.get(lesson)!;
    const prevSlug = orderedLessons[lessonIdx - 1] ?? null;
    const nextSlug = orderedLessons[lessonIdx + 1] ?? null;

    const prevLesson: LessonLink | null = prevSlug
      ? {
          href: `/lessons/${prevSlug}/${grouped.get(prevSlug)!.length}`,
          number: lessonNumber(prevSlug),
          title: lessonTitle(prevSlug),
        }
      : null;
    const nextLesson: LessonLink | null = nextSlug
      ? {
          href: `/lessons/${nextSlug}/1`,
          number: lessonNumber(nextSlug),
          title: lessonTitle(nextSlug),
        }
      : null;

    list.forEach((entry, i) => {
      paths.push({
        params: { lesson, step: String(i + 1) },
        props: {
          entry,
          step: i + 1,
          totalSteps: list.length,
          prevLesson,
          nextLesson,
        },
      });
    });
  });
  return paths;
}

const { entry, step, totalSteps, prevLesson, nextLesson } = Astro.props;
const { lesson } = Astro.params;
const { Content } = await render(entry);

const title = lessonTitle(lesson);
const num = lessonNumber(lesson);
const heading = num != null ? `${num}. ${title}` : title;

const lessonLabel = (l: LessonLink) =>
  l.number != null ? `Lesson ${l.number}: ${l.title}` : l.title;

const prevHref = step > 1 ? `/lessons/${lesson}/${step - 1}` : prevLesson?.href ?? null;
const prevIsBoundary = step === 1 && prevLesson != null;
const prevLabel = prevIsBoundary
  ? lessonLabel(prevLesson!)
  : prevHref
    ? `Step ${step - 1}`
    : null;

const nextHref = step < totalSteps ? `/lessons/${lesson}/${step + 1}` : nextLesson?.href ?? null;
const nextIsBoundary = step === totalSteps && nextLesson != null;
const nextLabel = nextIsBoundary
  ? lessonLabel(nextLesson!)
  : nextHref
    ? `Step ${step + 1}`
    : null;

const demoKey = `/lessons/${lesson}/${step}.demo`;
const goalKey = `/lessons/${lesson}/${step}.goal`;
const demo = demos[demoKey];
const goal = goals[goalKey];
---
<Base title={`${heading} (${step}/${totalSteps})`}>
  <p class="meta"><a href="/lessons">← All lessons</a></p>
  <h1>{heading}</h1>
  <p class="meta">Step {step} of {totalSteps}</p>
  <article>
    <Content />
  </article>
  {demo && <VimRunner start={demo} goal={goal} />}
  <nav class="step-nav">
    {prevHref ? (
      <a href={prevHref} class:list={["step-prev", prevIsBoundary && "lesson-boundary"]}>
        ← {prevLabel}
      </a>
    ) : <span />}
    <span class="meta">{step} / {totalSteps}</span>
    {nextHref ? (
      <a href={nextHref} class:list={["step-next", nextIsBoundary && "lesson-boundary"]}>
        {nextLabel} →
      </a>
    ) : <span />}
  </nav>
</Base>
