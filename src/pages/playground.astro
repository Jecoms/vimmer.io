---
import Base from "../layouts/Base.astro";
---
<Base title="Playground (vim.wasm POC)">
  <article>
    <h1>vim.wasm playground</h1>
    <p>
      A real Vim instance compiled to WebAssembly, running entirely in your
      browser. This page is a Phase 2 proof of concept — not yet wired to any
      lesson. Click the editor to focus, then type as you would in Vim.
    </p>
    <p class="meta" id="vim-status">Loading…</p>

    <div id="vim-host">
      <canvas id="vim-canvas" width="700" height="440"></canvas>
      <input id="vim-input" autocomplete="off" autocorrect="off" autocapitalize="off" spellcheck="false" />
    </div>

    <p class="meta" style="margin-top: 1rem;">
      <button id="read-buffer">Read buffer</button>
      &nbsp;Phase 3 layer 1: prove buffer-readback works.
    </p>
    <pre id="buffer-output" style="display: none;"></pre>

    <h2>Notes</h2>
    <ul>
      <li>If the editor never appears, your browser likely lacks
        <code>SharedArrayBuffer</code> support or the cross-origin-isolation
        headers didn't apply. Open devtools console for details.</li>
      <li>Try basic motion (<code>hjkl</code>), insert mode (<code>i</code>),
        and <code>:q</code>. The <code>!</code> shell isn't supported.</li>
    </ul>
  </article>
</Base>

<style>
  #vim-host {
    position: relative;
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: auto;
    line-height: 0;
    background: #000;
    max-width: 100%;
  }
  #vim-canvas {
    display: block;
  }
  #vim-input {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
</style>

<script>
  import { VimWasm, checkBrowserCompatibility } from "vim-wasm";

  const status = document.getElementById("vim-status")!;
  const canvas = document.getElementById("vim-canvas") as HTMLCanvasElement;
  const input = document.getElementById("vim-input") as HTMLInputElement;

  const incompatibility = checkBrowserCompatibility();
  if (incompatibility) {
    status.textContent = `This browser can't run vim.wasm: ${incompatibility}`;
  } else {
    const vim = new VimWasm({
      canvas,
      input,
      workerScriptPath: "/vim-wasm/vim.js",
    });

    // Our canvas is fixed-size, so vim.wasm's window-resize handler (which
    // resets canvas.width/height on every browser resize, clearing the
    // bitmap) is just causing flicker/blackouts. Neutralize it.
    const screen = (vim as unknown as { screen?: { resizer?: { doResize: () => void } } }).screen;
    if (screen?.resizer) {
      screen.resizer.doResize = () => {};
    }

    vim.onVimInit = () => {
      status.textContent = "Vim is running. Click the editor and start typing.";
    };
    vim.onVimExit = (code) => {
      status.textContent = `Vim exited with status ${code}.`;
    };
    vim.onError = (err) => {
      status.textContent = `Error: ${err.message}`;
      console.error(err);
    };

    document.getElementById("vim-host")!.addEventListener("click", () => {
      vim.focus();
    });

    const exercisePath = "/work/exercise.txt";
    const initial =
      "Welcome to vim.wasm.\n\n" +
      "This is a real Vim, not an emulator. Try moving with hjkl,\n" +
      "press i to insert, Esc to leave insert mode, and :q to quit.\n";

    vim.start({
      cmdArgs: ["-u", "NONE", "-i", "NONE", exercisePath],
      dirs: ["/work"],
      files: { [exercisePath]: initial },
    });

    function readBuffer(timeoutMs = 2000): Promise<string> {
      return new Promise((resolve, reject) => {
        const prev = vim.onFileExport;
        const t = setTimeout(() => {
          vim.onFileExport = prev;
          reject(new Error("Buffer read timed out"));
        }, timeoutMs);
        vim.onFileExport = (_path, contents) => {
          clearTimeout(t);
          vim.onFileExport = prev;
          resolve(new TextDecoder().decode(contents));
        };
        vim
          .cmdline(`silent write! ${exercisePath} | silent export ${exercisePath}`)
          .catch((err) => {
            clearTimeout(t);
            vim.onFileExport = prev;
            reject(err);
          });
      });
    }

    const out = document.getElementById("buffer-output") as HTMLPreElement;
    document.getElementById("read-buffer")!.addEventListener("click", async () => {
      out.style.display = "block";
      out.textContent = "Reading…";
      try {
        const contents = await readBuffer();
        out.textContent = `--- buffer (${contents.length} bytes) ---\n${contents}`;
      } catch (err) {
        out.textContent = `Failed: ${(err as Error).message}`;
      }
    });
  }
</script>
