---
interface Props {
  start: string;
  goal?: string;
}
const { start, goal } = Astro.props;
---
<div class="vim-runner" data-start={start} data-goal={goal ?? ""} data-has-goal={goal != null}>
  <p class="vim-status meta">Loading editor…</p>
  <div class="vim-host">
    <canvas class="vim-canvas" width="700" height="440"></canvas>
    <input
      class="vim-input"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
    />
  </div>
  <div class="vim-actions">
    <button type="button" class="vim-reset">Reset to start</button>
  </div>
</div>

<style>
  .vim-runner {
    margin: 1.75rem 0 1.25rem;
  }
  .vim-host {
    position: relative;
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: auto;
    line-height: 0;
    background: #000;
    max-width: 100%;
  }
  .vim-canvas {
    display: block;
  }
  .vim-input {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .vim-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .vim-actions button {
    font: inherit;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: var(--bg);
    color: var(--fg);
    cursor: pointer;
  }
  .vim-actions button:hover {
    border-color: var(--fg);
  }
  .vim-actions button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .vim-status.goal-reached {
    color: #16a34a;
    font-weight: 600;
  }
</style>

<script>
  import { VimWasm, checkBrowserCompatibility } from "vim-wasm";

  type ScreenInternal = {
    screen?: { resizer?: { doResize: () => void } };
  };

  const incompatibility = checkBrowserCompatibility();
  const exercisePath = "/work/exercise.txt";
  const pollPath = "/work/poll.txt";

  // Normalize for goal comparison: unify line endings, strip trailing
  // whitespace per line, drop trailing blank lines. Forgiving but not lax —
  // exact characters still have to match.
  const normalize = (s: string): string =>
    s
      .replace(/\r\n/g, "\n")
      .split("\n")
      .map((l) => l.replace(/\s+$/, ""))
      .join("\n")
      .replace(/\n+$/, "");

  for (const runner of document.querySelectorAll<HTMLElement>(".vim-runner")) {
    const start = runner.dataset.start ?? "";
    const goal = runner.dataset.hasGoal === "true" ? (runner.dataset.goal ?? "") : null;
    const status = runner.querySelector<HTMLElement>(".vim-status")!;
    const canvas = runner.querySelector<HTMLCanvasElement>(".vim-canvas")!;
    const input = runner.querySelector<HTMLInputElement>(".vim-input")!;
    const host = runner.querySelector<HTMLElement>(".vim-host")!;
    const resetBtn = runner.querySelector<HTMLButtonElement>(".vim-reset")!;

    if (incompatibility) {
      status.textContent = `This browser can't run the editor: ${incompatibility}`;
      resetBtn.disabled = true;
      continue;
    }

    // Phone soft keyboards break vim.wasm (focus, keycodes, viewport). Bail
    // before constructing VimWasm so we don't fetch the WASM on mobile.
    const isMobile = window.matchMedia(
      "(pointer: coarse), (max-width: 720px)",
    ).matches;
    if (isMobile) {
      status.textContent =
        "This lesson is best on a desktop browser — the editor needs a real keyboard.";
      status.classList.add("vim-notice");
      host.hidden = true;
      runner.querySelector<HTMLElement>(".vim-actions")!.hidden = true;
      continue;
    }

    const vim = new VimWasm({
      canvas,
      input,
      workerScriptPath: "/vim-wasm/vim.js",
    });

    const internal = vim as unknown as ScreenInternal;
    if (internal.screen?.resizer) {
      internal.screen.resizer.doResize = () => {};
    }

    vim.onVimInit = () => {
      status.textContent = "Editor ready — click it and try the exercise.";
    };
    vim.onVimExit = () => {
      status.textContent = "Editor exited. Refresh the page to restart.";
    };
    vim.onError = (err) => {
      status.textContent = `Error: ${err.message}`;
      console.error(err);
    };

    host.addEventListener("click", () => vim.focus());

    // Vim's cmdline tokenizer splits on `|` even inside string literals, so
    // any pipe in the line content (e.g. the basic-navigation demo's diagram)
    // would chop the call into garbage. Avoid the issue entirely by emitting
    // pipes as `nr2char(124)` and concatenating, so no raw `|` ever appears
    // in the cmdline text.
    const lineToExpr = (line: string): string => {
      const quote = (s: string) => `'${s.replace(/'/g, "''")}'`;
      if (!line.includes("|")) return quote(line);
      return line.split("|").map(quote).join(".nr2char(124).");
    };

    const splitLines = (s: string): string[] => {
      const lines = s.replace(/\r\n/g, "\n").split("\n");
      // Drop the trailing empty from a final "\n" — that represents the
      // file's EOF newline, not a blank line in the buffer.
      if (lines.length > 0 && lines[lines.length - 1] === "") lines.pop();
      return lines;
    };

    resetBtn.addEventListener("click", async () => {
      resetBtn.disabled = true;
      try {
        const lines = splitLines(start);
        // Set line 1 first (the empty line %delete leaves behind), then
        // append the rest. Per-line is more chatty than `call append(0, [...])`
        // but each cmdline contains only one string expression, which makes
        // failures land on a specific call we can catch.
        await vim.cmdline("silent! %delete _");
        if (lines.length > 0) {
          await vim.cmdline(`call setline(1, ${lineToExpr(lines[0])})`);
        }
        for (let i = 1; i < lines.length; i++) {
          await vim.cmdline(`call append(${i}, ${lineToExpr(lines[i])})`);
        }
        await vim.cmdline("silent! 1");
        // vim.wasm's cmdline path does NOT trigger a screen redraw on its own
        // (the source warns about this in a comment) — without this the canvas
        // keeps showing the pre-reset content until vim has another reason to
        // repaint, e.g. the user pressing a key.
        await vim.cmdline("redraw!");
        status.textContent = "Editor reset to start.";
      } catch (err) {
        status.textContent = `Reset failed: ${(err as Error).message}`;
        console.error("VimRunner reset failed:", err);
      } finally {
        resetBtn.disabled = false;
      }
    });

    // Polled buffer-readback for goal detection. We write to a side path
    // (pollPath) instead of the active file so the buffer's modified flag
    // isn't toggled every tick. :export then ships the file's bytes back to
    // JS via the onFileExport callback.
    const readBuffer = (): Promise<string> =>
      new Promise((resolve, reject) => {
        const prev = vim.onFileExport;
        const t = setTimeout(() => {
          vim.onFileExport = prev;
          reject(new Error("Buffer read timed out"));
        }, 1500);
        vim.onFileExport = (_path, contents) => {
          clearTimeout(t);
          vim.onFileExport = prev;
          resolve(new TextDecoder().decode(contents));
        };
        vim
          .cmdline(`silent write! ${pollPath} | silent export ${pollPath}`)
          .catch((err) => {
            clearTimeout(t);
            vim.onFileExport = prev;
            reject(err);
          });
      });

    if (goal != null) {
      const targetNorm = normalize(goal);
      let pollInFlight = false;
      let goalReached = false;
      const tick = async () => {
        if (goalReached || pollInFlight || !vim.isRunning()) return;
        pollInFlight = true;
        try {
          const current = await readBuffer();
          if (!goalReached && normalize(current) === targetNorm) {
            goalReached = true;
            status.textContent = "✓ Goal reached — try the next step";
            status.classList.add("goal-reached");
            document.body.classList.add("vim-goal-reached");
          }
        } catch {
          // vim was busy or transient error; try again next tick
        } finally {
          pollInFlight = false;
        }
      };
      const previousVimInit = vim.onVimInit;
      vim.onVimInit = () => {
        previousVimInit?.();
        // Poll a touch faster than once a second — fast enough to feel
        // immediate when a learner finishes, slow enough not to thrash.
        setInterval(tick, 750);
      };
    }

    vim.start({
      cmdArgs: ["-u", "NONE", "-i", "NONE", exercisePath],
      dirs: ["/work"],
      files: { [exercisePath]: start },
    });
  }
</script>
